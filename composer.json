{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "notification-service/app",
    "type": "project",
    "description": "Mass notification microservice (SMS/Email) with RabbitMQ prioritization",
    "keywords": ["laravel", "notifications", "rabbitmq"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "predis/predis": "^3.4",
        "vladimir-yuldashev/laravel-queue-rabbitmq": "^14.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd\" \"php artisan rabbitmq:consume rabbitmq --queue=notifications-critical,notifications-normal\" \"php artisan pail --timeout=0\" --names=worker,logs --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test:docker": [
            "docker compose run --rm --no-deps -e DB_CONNECTION=sqlite -e DB_DATABASE=:memory: -e CACHE_STORE=array -e QUEUE_CONNECTION=sync --entrypoint php php artisan test"
        ],
        "cs-fix": [
            "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer/vendor/bin/php-cs-fixer fix --config=php-cs-fixer/.php-cs-fixer.dist.php -v"
        ],
        "cs-fix:check": [
            "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer/vendor/bin/php-cs-fixer fix --config=php-cs-fixer/.php-cs-fixer.dist.php --dry-run --diff"
        ],
        "test:integration": [
            "@php artisan config:clear --ansi",
            "docker compose run --rm -e APP_ENV=testing -e DB_CONNECTION=pgsql -e DB_HOST=postgres -e DB_DATABASE=notifications -e DB_USERNAME=notifications -e DB_PASSWORD=secret -e CACHE_STORE=redis -e REDIS_CLIENT=predis -e REDIS_HOST=redis -e QUEUE_CONNECTION=rabbitmq -e RABBITMQ_HOST=rabbitmq -e RABBITMQ_USER=guest -e RABBITMQ_PASSWORD=guest --entrypoint php php vendor/bin/phpunit -c phpunit.integration.xml"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
